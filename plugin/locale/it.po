#: qpip.py:269
msgid ""
"%s : Switch to channel list\n"
"Ok key : Remove selected channel\n"
"PVR key : Input channel name\n"
"Exit key : Finish channel edit"
msgstr ""
"%s: Passa all'elenco dei canali\n"
"Tasto OK: Rimuovi il canale selezionato\n"
"Tasto PVR: Inserisci il nome del canale\n"
"Tasto Esci: Termina la modifica del canale"

#: qpip.py:267
msgid ""
"%s : Switch to quad PiP entry\n"
"Ok key : Add to new entry\n"
"PVR key : Input channel name\n"
"Exit key : Finish channel edit"
msgstr ""
"%s: Passa alla modalita PiP quadrupla\n"
"Tasto OK: Aggiungi a una nuova voce\n"
"Tasto PVR: Inserisci il nome del canale\n"
"Tasto Esci: Termina la modifica del canale"

